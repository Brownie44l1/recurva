# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://recurva:recurva@localhost:5432/recurva
DATABASE_SSL=false
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=20

# ─── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
PORTAL_JWT_EXPIRES_IN=1h

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Nomba (Payment Processor) ──────────────────────────────────────────────────
NOMBA_LIVE_SECRET=sk_live_your_nomba_secret
NOMBA_LIVE_ACCOUNT_ID=acc_live_your_account
NOMBA_SANDBOX_SECRET=sk_test_your_nomba_secret
NOMBA_SANDBOX_ACCOUNT_ID=acc_test_your_account
NOMBA_WEBHOOK_SECRET=nomb_whsec_your_webhook_secret
NOMBA_LIVE_BASE_URL=https://api.nomba.com
NOMBA_SANDBOX_BASE_URL=https://sandbox-api.nomba.com

# ─── Encryption ─────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32-byte-hex-string-for-aes-256-gcm

# ─── Scheduler ──────────────────────────────────────────────────────────────────
BILLING_CRON=0 6 * * *
DUNNING_CRON=0 * * * *
WEBHOOK_RETRY_CRON=*/15 * * * *
