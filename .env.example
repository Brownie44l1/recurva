# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://recurva:recurva@localhost:5432/recurva
DATABASE_SSL=false
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=20

# ─── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_at_least_64_chars
JWT_EXPIRES_IN=15m
PORTAL_JWT_EXPIRES_IN=1h

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Nomba (Payment Processor) ──────────────────────────────────────────────────
NOMBA_ENV=test
NOMBA_PARENT_ACCOUNT_ID=your_nomba_parent_account_id
NOMBA_SUB_ACCOUNT_ID=your_nomba_sub_account_id
NOMBA_TEST_CLIENT_ID=your_nomba_test_client_id
NOMBA_TEST_PRIVATE_KEY=your_nomba_test_private_key
NOMBA_LIVE_CLIENT_ID=your_nomba_live_client_id
NOMBA_LIVE_PRIVATE_KEY=your_nomba_live_private_key
NOMBA_INBOUND_WEBHOOK_SECRET=your_nomba_inbound_webhook_secret

# ─── Encryption ─────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your_32_byte_hex_string_for_aes_256_gcm

# ─── Scheduler ──────────────────────────────────────────────────────────────────
BILLING_CRON=0 6 * * *
DUNNING_CRON=0 * * * *
WEBHOOK_RETRY_CRON=*/15 * * * *
