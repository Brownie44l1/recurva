{
  "name": "recurva",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "migrate": "bun run src/db/migrate.ts",
    "migrate:rollback": "bun run src/db/migrate.ts --rollback",
    "typecheck": "bun run tsc --noEmit",
    "lint": "bun run tsc --noEmit"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/node": "^10.63.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.7.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "real-require": "0.2.0",
    "resend": "^6.17.1",
    "thread-stream": "3.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
