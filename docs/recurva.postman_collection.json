{
  "info": {
    "name": "Recurva API",
    "description": "Subscription billing API. All /v1/* endpoints require an API key (Bearer token) unless noted.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "recurva"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "api_key", "value": "rcv_live_your_key_here" },
    { "key": "dashboard_token", "value": "" },
    { "key": "portal_token", "value": "" },
    { "key": "customer_id", "value": "" },
    { "key": "plan_id", "value": "" },
    { "key": "subscription_id", "value": "" },
    { "key": "invoice_id", "value": "" },
    { "key": "endpoint_id", "value": "" },
    { "key": "coupon_id", "value": "" },
    { "key": "payment_method_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{api_key}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Tenants",
      "item": [
        {
          "name": "Register Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('api_key', json.apiKey);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Company\",\n  \"email\": \"admin@company.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/v1/tenants/register", "host": ["{{base_url}}"], "path": ["v1", "tenants", "register"] }
          }
        },
        {
          "name": "Get Tenant Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/v1/tenants/me", "host": ["{{base_url}}"], "path": ["v1", "tenants", "me"] }
          }
        }
      ]
    },
